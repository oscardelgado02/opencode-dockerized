# Safe OpenCode Docker - Environment Configuration
# Copy this file to .env and adjust values as needed.
#
# Presets are available for quick setup:
#   .env.safe      - All permissions require approval (most secure)
#   .env.auto      - All permissions allowed (fastest, for trusted environments)
#   .env.balanced  - Read/glob/grep/list allowed, others require approval
#
# To use a preset, copy it to .env:
#   cp .env.safe .env

# -----------------------------------------------------------------------------
# Docker Build Settings
# -----------------------------------------------------------------------------
# Pin specific versions if needed (leave empty or "latest" for newest)
# NODE_VERSION=alpine
# PNPM_VERSION=
# OPENCODE_VERSION=

# Working directory to mount into the container
WORKDIR=.

# -----------------------------------------------------------------------------
# OpenCode Permissions
# Values: ask | allow | deny
# -----------------------------------------------------------------------------
OPENCODE_PERMISSION_READ=ask
OPENCODE_PERMISSION_EDIT=ask
OPENCODE_PERMISSION_BASH=ask
OPENCODE_PERMISSION_GLOB=ask
OPENCODE_PERMISSION_GREP=ask
OPENCODE_PERMISSION_LIST=ask
OPENCODE_PERMISSION_WEBFETCH=ask
OPENCODE_PERMISSION_WEBSEARCH=ask
OPENCODE_PERMISSION_TASK=ask
OPENCODE_PERMISSION_EXTERNAL_DIRECTORY=ask

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
# Cloud model (e.g., anthropic/claude-3-opus, openai/gpt-4)
# OPENCODE_MODEL=

# Local model via Docker Model Runner (e.g., ai/smollm2, ai/qwen2.5-coder, ai/llama3.2)
# Pull models with: docker model pull ai/smollm2
# OPENCODE_LOCAL_MODEL_URL=http://model-runner.docker.internal:12434

# -----------------------------------------------------------------------------
# API Keys
# Set your provider API keys here so they persist across sessions.
# These are passed into the container at runtime.
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
