# Preset: Balanced Mode
# Reading and searching allowed freely; writing and execution require approval.
# Best for: everyday development where you want fast reads but safe writes.

WORKDIR=.

OPENCODE_PERMISSION_READ=allow
OPENCODE_PERMISSION_EDIT=ask
OPENCODE_PERMISSION_BASH=ask
OPENCODE_PERMISSION_GLOB=allow
OPENCODE_PERMISSION_GREP=allow
OPENCODE_PERMISSION_LIST=allow
OPENCODE_PERMISSION_WEBFETCH=ask
OPENCODE_PERMISSION_WEBSEARCH=ask
OPENCODE_PERMISSION_TASK=ask
OPENCODE_PERMISSION_EXTERNAL_DIRECTORY=allow

# OPENCODE_MODEL=
# OPENCODE_LOCAL_MODEL_URL=http://model-runner.docker.internal:12434

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
