# Preset: Auto Mode
# All permissions are pre-approved for fast, uninterrupted workflows.
# Best for: trusted codebases, CI/CD, automated pipelines.
# WARNING: OpenCode can read, write, and execute without confirmation.

UID=1000
GID=1000
WORKDIR=.

OPENCODE_PERMISSION_READ=allow
OPENCODE_PERMISSION_EDIT=allow
OPENCODE_PERMISSION_BASH=allow
OPENCODE_PERMISSION_GLOB=allow
OPENCODE_PERMISSION_GREP=allow
OPENCODE_PERMISSION_LIST=allow
OPENCODE_PERMISSION_WEBFETCH=allow
OPENCODE_PERMISSION_WEBSEARCH=allow
OPENCODE_PERMISSION_TASK=allow
OPENCODE_PERMISSION_EXTERNAL_DIRECTORY=allow

# OPENCODE_MODEL=
# OPENCODE_LOCAL_MODEL_URL=http://model-runner.docker.internal:12434

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
